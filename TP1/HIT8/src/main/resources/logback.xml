<!-- logback.xml — src/main/resources/logback.xml -->
<!--
  TP2 -PARTE 3- HIT 5: 2 appenders en paralelo.
    - CONSOLE → JSON a stdout via LogstashEncoder (Loki vía filelog, igual que antes)
    - OTEL    → bridge al SDK OTel, envía por gRPC al collector DaemonSet
  Los call-sites LOG.info/warn/error no se modifican.
-->
<configuration>

  <!-- ── Appender 1: JSON a stdout ─────────────────────────────────────── -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">

      <!--
        Renombrar campos al nivel que espera Loki/Kibana.
        [ignore] = omitir ese campo del JSON de salida.
      -->
      <fieldNames>
        <timestamp>timestamp</timestamp>
        <version>[ignore]</version>
        <levelValue>[ignore]</levelValue>
        <logger>logger</logger>
        <thread>thread</thread>
        <level>level</level>
        <message>message</message>
        <stackTrace>stack_trace</stackTrace>
      </fieldNames>

      <!--
        Incluir claves MDC como campos JSON de primer nivel.
        LogstashEncoder incluye TODO el MDC por defecto, pero listándolas
        explícitamente se documenta qué campos espera el pipeline.
      -->
      <includeMdcKeyName>producto</includeMdcKeyName>
      <includeMdcKeyName>browser</includeMdcKeyName>
      <includeMdcKeyName>intento</includeMdcKeyName>

    </encoder>
  </appender>

  <!-- ── Appender 2: Bridge Logback → OTel SDK (HIT 5) ────────────────── -->
  <!--
    Captura los mismos eventos que CONSOLE y los reenvía al LoggerProvider
    inicializado en OtelSetup.init().
    captureExperimentalAttributes=true → agrega campos como thread.name, etc.
    captureMdcAttributes → los mismos campos MDC llegan como atributos OTel,
    por eso aparecen como labels filtrables en Loki y campos en Kibana.
  -->
  <appender name="OTEL"
            class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
    <captureExperimentalAttributes>true</captureExperimentalAttributes>
    <captureMdcAttributes>producto,browser,intento</captureMdcAttributes>
  </appender>

  <!-- ── Root logger: los dos appenders activos ────────────────────────── -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="OTEL"/>
  </root>

</configuration>