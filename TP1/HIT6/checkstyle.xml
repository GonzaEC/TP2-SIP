<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  checkstyle.xml
  ─────────────────────────────────────────────────────────────────────────────
  Reglas de estilo para el proyecto. Alineadas con Google Java Format
  (que ya aplica Spotless), por lo que en la práctica Checkstyle actúa
  como segunda red de seguridad para reglas estructurales que el formatter
  no puede corregir automáticamente.
-->
<module name="Checker">

    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- ── Nivel de archivo ──────────────────────────────────────────────── -->
    <module name="FileTabCharacter">
        <!-- Spotless usa espacios; tabs son un error -->
        <property name="eachLine" value="true"/>
    </module>

    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf"/>
    </module>

    <!-- Líneas no más largas de 120 caracteres -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <!-- Ignorar líneas que son solo un import o una URL -->
        <property name="ignorePattern" value="^(import |.*https?://)"/>
    </module>

    <!-- ── Nivel de árbol (por clase/método) ─────────────────────────────── -->
    <module name="TreeWalker">

        <!-- Imports -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="IllegalImport">
            <!-- Prohibir sun.* que no es API pública -->
            <property name="illegalPkgs" value="sun"/>
        </module>

        <!-- Llaves -->
        <module name="NeedBraces">
            <!-- if/else/for/while siempre con llaves -->
            <property name="tokens" value="LITERAL_IF, LITERAL_ELSE,
                                           LITERAL_FOR, LITERAL_WHILE,
                                           LITERAL_DO"/>
        </module>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>

        <!-- Espacios en blanco -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods"      value="true"/>
            <property name="allowEmptyTypes"        value="true"/>
            <property name="allowEmptyLambdas"      value="true"/>
        </module>
        <!--<module name="NoWhitespaceAtEndOfLine"/>-->

        <!-- Convenciones de nombres -->
        <module name="TypeName"/>           <!-- PascalCase para clases    -->
        <module name="MethodName"/>         <!-- camelCase para métodos    -->
        <module name="LocalVariableName"/>  <!-- camelCase para variables  -->
        <module name="ConstantName"/>       <!-- UPPER_SNAKE para static final -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- Modificadores en orden estándar (JLS §8.1.1) -->
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>

        <!-- Buenas prácticas -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>
        <module name="EmptyCatchBlock">
            <!-- Permite catch vacío solo si tiene un comentario -->
            <property name="exceptionVariableName" value="expected|ignored|ignore|noop"/>
        </module>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="StringLiteralEquality"/>
        <module name="EqualsHashCode"/>

        <!-- Javadoc mínimo en clases públicas (warning, no error) -->
        <module name="MissingJavadocType">
            <property name="severity" value="warning"/>
            <property name="scope"    value="public"/>
        </module>

    </module>

</module>
